# Production environment for packaged Cipher builds.
#
# This file is GITIGNORED. CI / release packaging writes it on the build
# machine from a secret store, the resulting .env.production is then bundled
# into the installer via electron-builder's `extraResources` (see
# package.json).
#
# At runtime, Cipher/main.js loads this file before `.env` and seeds
# process.env — the Python subprocess that talks to the lock server
# inherits these values.

# Lock server URL + HMAC secret for production vault registration.
# The secret MUST match EIDOLON_LOCK_API_SECRET on the VPS.
# Rotate both on the VPS AND in CI when the secret leaks.
EIDOLON_SERVER_URL=https://lock.eidolon-connect.xyz
EIDOLON_API_SECRET=<replace-with-prod-hex-secret>

# Eidolon Connect API (Phase 2 SDK reach-out) — used by Cipher's
# cross-device QR flow. Leave commented until the Connect service is live.
# EIDOLON_CONNECT_URL=https://api.eidolon-connect.xyz
# EIDOLON_CONNECT_SESSION_SECRET=<replace-with-connect-secret>
