# =============================================================================
# CIPHER PULSE - BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill with your real values
# NEVER commit the .env file to version control!
# =============================================================================

# =============================================================================
# JWT AUTHENTICATION (REQUIRED)
# =============================================================================
# Generate a secure 128-character random string
# NO "secret" keyword allowed for security
# Example generator: openssl rand -base64 96
JWT_SECRET=YOUR_128_CHARACTER_RANDOM_STRING_HERE

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=4000
NODE_ENV=development

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:port/database

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# =============================================================================
# UPLOAD LIMITS
# =============================================================================
MAX_ACTIVE_UPLOADS_PER_USER=3

# =============================================================================
# STRIPE PAYMENTS (REQUIRED for contribution features)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/test/apikeys
#
# TEST MODE (development):
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
#
# PRODUCTION MODE (uncomment when deploying):
# STRIPE_SECRET_KEY=sk_live_YOUR_PRODUCTION_SECRET_KEY_HERE
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET_HERE

# Frontend URL for redirects after payment
FRONTEND_URL=http://localhost:5173

# =============================================================================
# CONTRIBUTION SETTINGS
# =============================================================================
# Supported currencies (comma-separated)
SUPPORTED_CURRENCIES=EUR,USD,GBP,CNY

# Default currency
DEFAULT_CURRENCY=EUR

# =============================================================================
# BLOCKCHAIN (Optional - for Time-Lock features)
# =============================================================================
BLOCKCHAIN_NETWORK=simulated-chimera

# =============================================================================
# EIDOLON CONNECT (Optional - gated until Eidolon ecosystem is public)
# =============================================================================
# When false (default), backend routes that reach the external Eidolon API
# (/api/v2/auth/eidolon-connect/session and the Connect exchange path of
# /api/v2/auth/eidolon-bridge/session) return 503. The desktop PSNX path of
# eidolon-bridge/session remains available regardless of this flag.
EIDOLON_CONNECT_ENABLED=false

# =============================================================================
# TIMELOCK (Legacy feature, disabled pending drand/tlock migration)
# =============================================================================
# The current time-lock only gates message delivery on block height server-
# side. A modified client or compromised server can serve content early,
# so this is *not* a trustless timelock. It's gated off until the drand/
# tlock migration ships a cryptographically enforced lock.
TIMELOCK_ENABLED=false
