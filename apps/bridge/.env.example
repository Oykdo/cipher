# =============================================================================
# CIPHER PULSE - BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill with your real values
# NEVER commit the .env file to version control!
# =============================================================================

# =============================================================================
# JWT AUTHENTICATION (REQUIRED)
# =============================================================================
# Generate a secure 128-character random string
# NO "secret" keyword allowed for security
# Example generator: openssl rand -base64 96
JWT_SECRET=YOUR_128_CHARACTER_RANDOM_STRING_HERE

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=4000
NODE_ENV=development

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:port/database

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# =============================================================================
# UPLOAD LIMITS
# =============================================================================
MAX_ACTIVE_UPLOADS_PER_USER=3

# =============================================================================
# STRIPE PAYMENTS (optional — leave empty to disable contribution endpoints)
# =============================================================================
# For LOCAL DEV: paste sk_test_* and whsec_test_* below.
#   - Get the test secret key:    https://dashboard.stripe.com/test/apikeys
#   - Generate a webhook secret:  install Stripe CLI, run `stripe login`,
#     then `stripe listen --forward-to localhost:4000/api/public/stripe/webhook`.
#     The whsec_* it prints is your local dev webhook secret. Trigger an
#     event with `stripe trigger checkout.session.completed`.
#
# NEVER paste sk_live_* or production whsec_* here. Production secrets live
# ONLY in `fly secrets set ... --app cipher-bridge`. A leaked sk_live_*
# allows real money to be charged on your Stripe account.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL for redirects after payment
FRONTEND_URL=http://localhost:5173

# =============================================================================
# CONTRIBUTION SETTINGS
# =============================================================================
# Supported currencies (comma-separated)
SUPPORTED_CURRENCIES=EUR,USD,GBP,CNY

# Default currency
DEFAULT_CURRENCY=EUR

# =============================================================================
# BLOCKCHAIN (Optional - for Time-Lock features)
# =============================================================================
BLOCKCHAIN_NETWORK=simulated-chimera

# =============================================================================
# EIDOLON CONNECT (Optional - gated until Eidolon ecosystem is public)
# =============================================================================
# When false (default), backend routes that reach the external Eidolon API
# (/api/v2/auth/eidolon-connect/session and the Connect exchange path of
# /api/v2/auth/eidolon-bridge/session) return 503. The desktop PSNX path of
# eidolon-bridge/session remains available regardless of this flag.
EIDOLON_CONNECT_ENABLED=false

# Note: TIMELOCK_ENABLED was retired in v1.2.4. Time-locked messages
# now use drand/tlock (BLS12-381 IBE towards a future drand round) and
# ship unconditionally — the bridge passes the round number through
# opaquely, no env gate needed. See apps/frontend/src/lib/tlock.ts.
