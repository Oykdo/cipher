# Privacy-l1 production environment for the bundled Electron build.
#
# These variables are inlined into the frontend bundle by Vite at
# `npm run build:frontend` time (Vite reads .env.production when
# `--mode production` is active, which is the default for `vite build`).
# They cannot be changed at runtime — the URL is baked into the .exe.
#
# Updating: edit this file, then rebuild with `npm run build:win`.
# Distribute the new installer.

# Hosted bridge — see DESK-2 (Fly.io deployment, Paris region).
VITE_API_BASE_URL=https://cipher-bridge.fly.dev
VITE_WS_BASE_URL=wss://cipher-bridge.fly.dev
VITE_SOCKET_URL=https://cipher-bridge.fly.dev

# Eidolon Connect — vault-based authentication via eidolon-connect.xyz
VITE_EIDOLON_CONNECT_ENABLED=true
VITE_EIDOLON_CONNECT_URL=https://eidolon-connect.xyz
VITE_EIDOLON_CONNECT_APP_ID=cipher.desktop

# Note: VITE_TIMELOCK_ENABLED was retired in v1.2.4. Time-locked messages
# use drand/tlock unconditionally (no env gate needed).

# P2P opportunistic transport (frontend-side flag — server already supports it).
VITE_P2P_ENABLED=true
