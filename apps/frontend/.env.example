# =============================================================================
# CIPHER PULSE - FRONTEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.development for local development
# NEVER commit .env files with real credentials!
# =============================================================================

# =============================================================================
# API ENDPOINTS (REQUIRED)
# =============================================================================
VITE_API_BASE_URL=http://localhost:4000
VITE_WS_BASE_URL=ws://localhost:4000

# =============================================================================
# STRIPE PAYMENTS (REQUIRED for contribution features)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/test/apikeys
# 
# TEST MODE (development):
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
#
# PRODUCTION MODE (uncomment when deploying):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PRODUCTION_KEY_HERE

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# Enable/disable contribution features
VITE_ENABLE_CONTRIBUTIONS=true

# Enable/disable P2P features
VITE_ENABLE_P2P=true

# =============================================================================
# EIDOLON INSTALL FLOW (Optional)
# =============================================================================
VITE_EIDOLON_DOWNLOAD_URL=https://github.com/Oykdo/Project_Logos/releases
VITE_EIDOLON_INFO_URL=https://github.com/Oykdo/Project_Logos/releases
VITE_EIDOLON_CONNECT_URL=http://127.0.0.1:8000
VITE_EIDOLON_CONNECT_APP_ID=cipher.desktop
# Eidolon Connect integration is gated until the Eidolon ecosystem is public.
# Set to "true" to enable probe/registration + Connect sessions. Default: off.
VITE_EIDOLON_CONNECT_ENABLED=false

# Note: VITE_TIMELOCK_ENABLED was retired in v1.2.4. Time-locked
# messages now use drand/tlock (BLS12-381 IBE) which is cryptographic
# and ships unconditionally — no env gate needed. The Time-Lock pill
# is always available in the composer. See src/lib/tlock.ts.
